# 朝廷政务管理系统 - 环境变量配置示例

# ==================== 数据库配置 ====================
DATABASE_URL=mysql+pymysql://court_admin:change_me_db_password@localhost:3306/court_admin?charset=utf8mb4

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=court_admin
MYSQL_USER=court_admin
MYSQL_PASSWORD=change_me_db_password

# docker-compose 对外暴露 MySQL 端口（可选）
MYSQL_EXPOSE_PORT=9003

# ==================== OpenClaw 配置 ====================
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json

# ==================== 备份配置 ====================
BACKUP_DIR=/root/court-admin/data/backups

# ==================== 服务端口 ====================
BACKEND_PORT=9001
FRONTEND_PORT=9002

# ==================== 日志配置 ====================
LOG_DIR=/root/court-admin/logs
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# 若配置后端管理口令，调用 /api/config* 需请求头 X-Admin-Token
CONFIG_ADMIN_TOKEN=

# 允许跨域来源（逗号分隔）
CORS_ORIGINS=http://localhost:9002,http://127.0.0.1:9002

# 是否允许后端执行网关重启命令
ENABLE_RELOAD_COMMAND=true
OPENCLAW_RELOAD_COMMAND=openclaw gateway restart

# 其他
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
