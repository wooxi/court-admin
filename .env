# 朝廷政务管理系统 - 环境变量配置

# ==================== 数据库配置 ====================
# MySQL 数据库连接信息
# 格式：mysql+pymysql://用户名：密码@主机：端口/数据库名
DATABASE_URL=mysql+pymysql://root:ulikem00n@192.168.100.4:3306/court_admin

# MySQL root 密码（用于自动创建数据库）
MYSQL_ROOT_PASSWORD=ulikem00n

# MySQL 主机
MYSQL_HOST=192.168.100.4

# MySQL 端口
MYSQL_PORT=3306

# 数据库名称
MYSQL_DATABASE=court_admin

# 数据库用户名
MYSQL_USER=root

# 数据库密码
MYSQL_PASSWORD=ulikem00n

# ==================== OpenClaw 配置 ====================
# OpenClaw 配置文件路径
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json

# ==================== 备份配置 ====================
# 配置备份目录
BACKUP_DIR=/root/court-admin/data/backups

# ==================== 服务端口配置 ====================
# 后端 API 端口
BACKEND_PORT=9001

# 前端服务端口
FRONTEND_PORT=9002

# ==================== 日志配置 ====================
# 日志目录
LOG_DIR=/root/court-admin/logs

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# JWT Secret（用于用户认证，待实现）
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# JWT Token 过期时间（小时）
JWT_EXPIRE_HOURS=24

# ==================== 其他配置 ====================
# 调试模式 (true/false)
DEBUG=false

# 允许的主机列表（逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:9002,http://127.0.0.1:9002
