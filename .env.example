# 朝廷政务管理系统 - 环境变量配置示例

# ==================== 数据库配置 ====================
# 数据库连接 URL
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/court_admin

# MySQL 连接信息
MYSQL_ROOT_PASSWORD=your_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=court_admin
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# ==================== OpenClaw 配置 ====================
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json

# ==================== 备份配置 ====================
BACKUP_DIR=/root/court-admin/data/backups

# ==================== 服务端口 ====================
BACKEND_PORT=9001
FRONTEND_PORT=9002

# ==================== 日志配置 ====================
LOG_DIR=/root/court-admin/logs
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE_HOURS=24

# ==================== 其他配置 ====================
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:9002,http://127.0.0.1:9002
